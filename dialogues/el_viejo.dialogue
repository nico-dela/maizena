~ start

if GameState.quest_hambre_completed:
	El viejo: Gracias… ahora puedo seguir. => END

if GameState.tiene_comida:
	do GameState.completar_comida()
	El viejo: Gracias… de verdad. => END

if GameState.quest_hambre_active:
	El viejo: Sigo esperando… tengo hambre. => END

El viejo: … ¿Podrías buscarme algo para comer? Creo haber visto unos hongos en el bosque o en la playa …

- Si
	do GameState.buscar_comida()
	do HongosSpawner.spawn_cabbage()
	El viejo: Gracias… no tengo fuerzas para salir. => END

- No
	El viejo: Ya veo… entonces seguiré esperando. => END